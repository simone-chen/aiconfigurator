{#
  sflow_deploy.yaml.j2 — nv-sflow v0.1 workflow for Dynamo LLM inference.

  This template is a PURE orchestration skeleton.  All backend-specific
  logic (variables list, launch commands, operator config, probes) is
  pre-computed in sflow.py and injected via context.

  Convention: sflow runtime expressions use $[[ ... ]] in this template.
  After Jinja2 rendering, a post-processor converts them to ${{ ... }}.
#}
version: '0.1'
variables:
{% for var in sflow_variables %}
  {{ var.name }}:
    description: {{ var.description }}
{% if var.type %}
    type: {{ var.type }}
{% endif %}
    value: {{ var.value | tojson }}
{% if var.domain %}
    domain:
{% for item in var.domain %}
    - {{ item | tojson }}
{% endfor %}
{% endif %}
{% endfor %}
artifacts:
- name: LOCAL_MODEL_PATH
  uri: $[[ variables.LOCAL_MODEL_PATH ]]
{% if sflow_bench_run_content %}
- name: BENCH_RUN
  uri: file://bench_run.sh
  content: |
{{ sflow_bench_run_content | indent(4, true) }}
{% endif %}
{% if sflow_agg_engine_content %}
- name: AGG_CONFIG
  uri: file://agg_config.yaml
  content: |
{{ sflow_agg_engine_content | indent(4, true) }}
{% endif %}
{% if sflow_prefill_engine_content %}
- name: PREFILL_CONFIG
  uri: file://prefill_config.yaml
  content: |
{{ sflow_prefill_engine_content | indent(4, true) }}
{% endif %}
{% if sflow_decode_engine_content %}
- name: DECODE_CONFIG
  uri: file://decode_config.yaml
  content: |
{{ sflow_decode_engine_content | indent(4, true) }}
{% endif %}
backends:
- name: slurm_cluster
  type: slurm
  default: true
  time: $[[ variables.SLURM_TIMELIMIT ]]
  nodes: $[[ variables.SLURM_NODES ]]
  partition: $[[ variables.SLURM_PARTITION ]]
  account: $[[ variables.SLURM_ACCOUNT ]]
  gpus_per_node: $[[ variables.GPUS_PER_NODE ]]
operators:
- name: {{ sflow_operator }}
  type: srun
  container_image: $[[ variables.DYNAMO_IMAGE ]]
  container_writable: true
  mpi: pmix
- name: aiperf
  type: srun
  container_image: $[[ variables.AIPERF_IMAGE ]]
  container_writable: true
  mpi: pmix
workflow:
  name: dynamo_{{ backend }}_{{ sflow_mode }}
  timeout: 115m
  variables:
    HEAD_NODE_IP:
      description: Head node IP (resolved after allocation)
      value: $[[ backends.slurm_cluster.nodes[0].ip_address ]]
{% if backend != 'vllm' %}
    ETCD_ENDPOINTS:
      description: ETCD endpoints
      value: $[[ backends.slurm_cluster.nodes[0].ip_address ]]:2379
    NATS_SERVER:
      description: NATS server URL
      value: nats://$[[ backends.slurm_cluster.nodes[0].ip_address ]]:4222
{% endif %}
  tasks:
  - name: load_image
    operator:
      name: {{ sflow_operator }}
      ntasks: $[[ variables.SLURM_NODES ]]
      ntasks_per_node: 1
    script:
    - echo "Image Loaded"
    - sleep 3600
    probes:
      readiness:
        log_watch:
          regex_pattern: Image Loaded
          match_count: $[[ variables.SLURM_NODES ]]
        timeout: 1200
        interval: 2
  - name: gpu_monitor
    operator:
      name: {{ sflow_operator }}
      ntasks: $[[ variables.SLURM_NODES ]]
      ntasks_per_node: 1
    resources:
      nodes:
        count: $[[ variables.SLURM_NODES ]]
    script:
    - echo "Starting gpu monitor"
    - |-
      nvidia-smi --query-gpu=index,utilization.gpu,utilization.memory,temperature.gpu,temperature.memory,power.draw,clocks.sm,clocks.mem,memory.total,memory.used  \
        --format=csv,noheader,nounits -lms 2000 |  while IFS= read -r input || [ -n "$input" ] ;  do timestamp=$(date +%s%3N);  printf "%s.%s,%s\n" "${timestamp:0:10}" "${timestamp:10:3}" "${input}";  done  >> ${SFLOW_TASK_OUTPUT_DIR}/gpu_monitor_node_${SLURM_NODEID}_${SLURMD_NODENAME}.log
    probes:
      readiness:
        log_watch:
          regex_pattern: Starting gpu monitor
        timeout: 60
        interval: 2
    depends_on:
    - load_image
{% if backend != 'vllm' %}
  - name: nats_server
    operator: {{ sflow_operator }}
    script:
    - nats-server -js
    resources:
      nodes:
        indices:
        - 0
    probes:
      readiness:
        tcp_port:
          port: 4222
        timeout: 60
        interval: 2
    depends_on:
    - load_image
  - name: etcd_server
    operator: {{ sflow_operator }}
    script:
    - |-
      etcd --listen-client-urls "http://0.0.0.0:2379" \
        --advertise-client-urls "http://0.0.0.0:2379" \
        --listen-peer-urls "http://0.0.0.0:2380" \
        --initial-advertise-peer-urls "http://${HEAD_NODE_IP}:2380" \
        --initial-cluster "default=http://${HEAD_NODE_IP}:2380" \
        --data-dir /tmp/etcd
    resources:
      nodes:
        indices:
        - 0
    probes:
      readiness:
        tcp_port:
          port: 2379
        timeout: 60
        interval: 2
    depends_on:
    - load_image
{% endif %}
  - name: frontend_server
    operator: {{ sflow_operator }}
    script:
    - python3 -m dynamo.frontend --http-port 8000 $[[ variables.EXTRA_FRONTEND_ARGS ]]
    resources:
      nodes:
        indices:
        - 0
    probes:
      readiness:
        tcp_port:
          port: 8000
        timeout: 120
        interval: 5
    depends_on:
{% if backend == 'vllm' %}
    - load_image
{% else %}
    - nats_server
    - etcd_server
{% endif %}
{% if sflow_mode == 'agg' %}
  - name: agg_server
    operator:
      name: {{ sflow_operator }}
{% if sflow_agg_ntasks %}
      ntasks: {{ sflow_agg_ntasks }}
{% endif %}
      ntasks_per_node: {{ sflow_agg_ntasks_per_node }}
    replicas:
      count: {{ sflow_agg_replicas_count }}
      policy: {{ sflow_agg_replicas_policy }}
    script:
{{ sflow_agg_script | indent(4, true) }}
    resources:
      gpus:
        count: {{ sflow_agg_gpu_count }}
    depends_on:
    - frontend_server
    probes:
      readiness:
        log_watch:
          regex_pattern: {{ sflow_server_ready_pattern }}
        timeout: 600
        interval: 10
      failure:
        log_watch:
          regex_pattern: Traceback (most recent call last)
        interval: 10
{% else %}
  - name: prefill_server
    operator:
      name: {{ sflow_operator }}
{% if sflow_prefill_ntasks %}
      ntasks: {{ sflow_prefill_ntasks }}
{% endif %}
      ntasks_per_node: {{ sflow_prefill_ntasks_per_node }}
    replicas:
      count: {{ sflow_prefill_replicas_count }}
      policy: {{ sflow_prefill_replicas_policy }}
    script:
{{ sflow_prefill_script | indent(4, true) }}
    resources:
      gpus:
        count: {{ sflow_prefill_gpu_count }}
    depends_on:
    - frontend_server
    probes:
      readiness:
        log_watch:
          regex_pattern: {{ sflow_server_ready_pattern }}
        timeout: 600
        interval: 10
      failure:
        log_watch:
          regex_pattern: Traceback (most recent call last)
        interval: 10
  - name: decode_server
    operator:
      name: {{ sflow_operator }}
{% if sflow_decode_ntasks %}
      ntasks: {{ sflow_decode_ntasks }}
{% endif %}
      ntasks_per_node: {{ sflow_decode_ntasks_per_node }}
    replicas:
      count: {{ sflow_decode_replicas_count }}
      policy: {{ sflow_decode_replicas_policy }}
    script:
{{ sflow_decode_script | indent(4, true) }}
    resources:
      gpus:
        count: {{ sflow_decode_gpu_count }}
    depends_on:
    - frontend_server
    probes:
      readiness:
        log_watch:
          regex_pattern: {{ sflow_server_ready_pattern }}
        timeout: 600
        interval: 10
      failure:
        log_watch:
          regex_pattern: Traceback (most recent call last)
        interval: 10
{% endif %}
  - name: benchmark
    operator:
      name: aiperf
      ntasks: 1
    script:
{{ sflow_bench_script | indent(4, true) }}
    resources:
      nodes:
        indices:
        - 0
    replicas:
      variables:
      - CONCURRENCY
      policy: sequential
    depends_on:
{% if sflow_mode == 'disagg' %}
    - prefill_server
    - decode_server
{% else %}
    - agg_server
{% endif %}
    - frontend_server
