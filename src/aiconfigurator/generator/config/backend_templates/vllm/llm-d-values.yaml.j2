{#
llm-d Helm values.yaml template for llm-d-modelservice chart
Generates Helm values for deploying vLLM inference with llm-d platform
#}
{%- set service_config = ServiceConfig | default({}) -%}
{%- set dyn_config = DynConfig | default({}) -%}
{%- set llmd_config = LlmdConfig | default({}) -%}
{%- set model_name = service_config.model_path | default('meta-llama/Llama-3.1-8B') -%}
{%- set model_uri = "hf://" ~ model_name -%}
{%- set served_name = service_config.served_model_name | default(model_name.split('/')[-1], true) -%}

# llm-d-modelservice Helm values
# Generated by aiconfigurator for llm-d deployment

enabled: true

# Model configuration
modelArtifacts:
  name: {{ model_name }}
  labels:
    llm-d.ai/inference-serving: "true"
    llm-d.ai/model: {{ served_name | replace('-', '_') | replace('/', '_') }}
  uri: {{ model_uri }}
  size: {{ llmd_config.model_cache_size | default('100Gi') }}
  # hf_token should be the name of a K8s Secret containing the HF token
  {% if service_config.hf_token -%}
  authSecretName: {{ service_config.hf_token }}
  {% else -%}
  authSecretName: ""
  {% endif -%}
  mountPath: {{ llmd_config.model_mount_path | default('/model-cache') }}

# Accelerator configuration
accelerator:
  type: nvidia  # aiconfigurator currently supports NVIDIA GPUs
  dra: false

# Routing configuration
routing:
  servicePort: {{ service_config.port | default(8000) }}
  proxy:
    enabled: {{ llmd_config.routing_proxy_enabled | default(true) }}
    image: {{ llmd_config.routing_proxy_image | default('ghcr.io/llm-d/llm-d-routing-sidecar:latest') }}
    imagePullPolicy: Always
    targetPort: 8200
    connector: {{ llmd_config.routing_connector | default('nixlv2') }}
    zapLogLevel: {{ llmd_config.log_level | default('info') }}

{% if dyn_config.mode | default('disagg') == 'agg' -%}
# Aggregated mode - single decode worker
multinode: false

decode:
  create: true
  replicas: {{ agg_workers | default(1) }}

  parallelism:
    tensor: {{ agg_tensor_parallel_size | default(1) }}
    data: {{ agg_data_parallel_size | default(1) }}
    dataLocal: 1
    workers: 1

  containers:
    - name: vllm
      image: {{ llmd_config.vllm_image | default('vllm/vllm-openai:latest') }}
      modelCommand: vllmServe
      args:
        - --model
        - {{ model_name }}
        - --served-model-name
        - {{ served_name }}
        {%- for arg in agg_cli_args_list | default([]) %}
        - {{ arg | tojson }}
        {%- endfor %}
      env: []
      ports:
        - containerPort: 8200
          name: metrics
          protocol: TCP
      resources:
        limits:
          nvidia.com/gpu: {{ agg_gpu | default(1) }}
      mountModelVolume: true
      volumeMounts:
        - name: metrics-volume
          mountPath: /.config

  volumes:
    - name: metrics-volume
      emptyDir: {}

  {% if llmd_config.monitoring_enabled | default(false) -%}
  monitoring:
    podmonitor:
      enabled: true
      portName: metrics
      path: /metrics
      interval: 30s
  {% endif -%}

prefill:
  create: false
  replicas: 0

{% else -%}
# Disaggregated mode - separate prefill and decode workers
multinode: {{ llmd_config.multinode | default(false) }}

decode:
  create: true
  replicas: {{ decode_workers | default(1) }}

  parallelism:
    tensor: {{ decode_tensor_parallel_size | default(1) }}
    data: {{ decode_data_parallel_size | default(1) }}
    dataLocal: 1
    workers: 1

  containers:
    - name: vllm
      image: {{ llmd_config.vllm_image | default('vllm/vllm-openai:latest') }}
      modelCommand: vllmServe
      args:
        - --model
        - {{ model_name }}
        - --served-model-name
        - {{ served_name }}
        {%- for arg in decode_cli_args_list | default([]) %}
        - {{ arg | tojson }}
        {%- endfor %}
      env: []
      ports:
        - containerPort: 8200
          name: metrics
          protocol: TCP
      resources:
        limits:
          nvidia.com/gpu: {{ decode_gpu | default(1) }}
      mountModelVolume: true
      volumeMounts:
        - name: metrics-volume
          mountPath: /.config

  volumes:
    - name: metrics-volume
      emptyDir: {}

  {% if llmd_config.monitoring_enabled | default(false) -%}
  monitoring:
    podmonitor:
      enabled: true
      portName: metrics
      path: /metrics
      interval: 30s
  {% endif -%}

prefill:
  create: true
  replicas: {{ prefill_workers | default(1) }}

  parallelism:
    tensor: {{ prefill_tensor_parallel_size | default(1) }}
    data: {{ prefill_data_parallel_size | default(1) }}
    dataLocal: 1
    workers: 1

  containers:
    - name: vllm
      image: {{ llmd_config.vllm_image | default('vllm/vllm-openai:latest') }}
      modelCommand: vllmServe
      args:
        - --model
        - {{ model_name }}
        - --served-model-name
        - {{ served_name }}
        {%- for arg in prefill_cli_args_list | default([]) %}
        - {{ arg | tojson }}
        {%- endfor %}
      env: []
      ports:
        - containerPort: 8000
          name: metrics
          protocol: TCP
      resources:
        limits:
          nvidia.com/gpu: {{ prefill_gpu | default(1) }}
      mountModelVolume: true
      volumeMounts:
        - name: metrics-volume
          mountPath: /.config

  volumes:
    - name: metrics-volume
      emptyDir: {}

  {% if llmd_config.monitoring_enabled | default(false) -%}
  monitoring:
    podmonitor:
      enabled: true
      portName: metrics
      path: /metrics
      interval: 30s
  {% endif -%}
{% endif -%}
